# Required — Zabbix server URL (no trailing slash)
ZABBIX_URL=https://your-zabbix-server.example.com

# Required — Zabbix API token (created in Zabbix UI → Administration → API tokens)
# Requires Zabbix 5.4+; never commit this value to version control
ZABBIX_API_TOKEN=your_api_token_here

# Optional — HTTP request timeout in seconds (default: 10)
ZABBIX_TIMEOUT_SECONDS=10

# Optional — Maximum objects per Zabbix API page (default: 100)
ZABBIX_PAGE_LIMIT=100

# Optional — Log verbosity level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO
